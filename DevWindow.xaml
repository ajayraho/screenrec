<Window x:Class="ScreenRecApp.DevWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Developer Mode - ScreenRecApp" Height="400" Width="600"
        Background="#1e1e2e" Foreground="#cdd6f4"
        Topmost="True" ShowInTaskbar="False" WindowStyle="ToolWindow">
    <Grid>
        <TextBox x:Name="LogTextBox" TextWrapping="Wrap" AcceptsReturn="True" 
                 VerticalScrollBarVisibility="Auto" Background="#11111b" Foreground="#a6e3a1" 
                 FontFamily="Consolas" IsReadOnly="True" Margin="5"/>
    </Grid>
</Window>
