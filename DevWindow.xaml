<Window x:Class="ScreenRecApp.DevWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dev Monitor" Width="680" Height="460"
        Background="Transparent" Foreground="#cdd6f4"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResize"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="Manual"
        Left="20" Top="20"
        SnapsToDevicePixels="True" UseLayoutRounding="True">

    <Border Background="#11111b" CornerRadius="10" BorderBrush="#313244" BorderThickness="1" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" Direction="270" Opacity="0.5" ShadowDepth="2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title bar -->
                <RowDefinition Height="Auto"/>  <!-- Command bar -->
                <RowDefinition Height="*"/>     <!-- Log output -->
                <RowDefinition Height="Auto"/>  <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="#181825" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Margin="14,9">
                    <!-- Status dot -->
                    <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#a6e3a1" Margin="0,0,10,0" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#a6e3a1" BlurRadius="6" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="ScreenRecApp Monitor" FontSize="13" FontWeight="SemiBold" Foreground="#89b4fa" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusLabel" Text=" — Idle" FontSize="12" Foreground="#6c7086" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Clear button -->
                <Button Grid.Column="1" Content="Clear" Click="Clear_Click" Width="52" Height="26" Margin="0,0,4,0"
                        Background="#313244" Foreground="#a6adc8" BorderThickness="0" FontSize="11" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#45475a"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Close button -->
                <Button Grid.Column="2" Content="✕" Click="Close_Click" Width="40" Height="30"
                        Background="Transparent" Foreground="#f38ba8" BorderThickness="0" FontSize="15" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#313244"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Last command bar -->
            <Border Grid.Row="1" Background="#1e1e2e" BorderBrush="#313244" BorderThickness="0,0,0,1" Padding="12,7">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="CMD " Foreground="#6c7086" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LastCommandText" Text="—" Foreground="#f9e2af" FontFamily="Consolas" FontSize="11"
                               TextTrimming="CharacterEllipsis" MaxWidth="560" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Log Textbox -->
            <TextBox x:Name="LogTextBox"
                     Grid.Row="2"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Background="#11111b" Foreground="#a6e3a1"
                     CaretBrush="#a6e3a1"
                     FontFamily="Consolas" FontSize="12"
                     IsReadOnly="True" Padding="12,10"
                     BorderThickness="0"
                     TextOptions.TextFormattingMode="Display"
                     SelectionBrush="#313244"/>

            <!-- Footer -->
            <Border Grid.Row="3" Background="#181825" BorderBrush="#313244" BorderThickness="0,1,0,0" Padding="12,6">
                <Grid>
                    <TextBlock x:Name="LineCountText" Text="0 lines" Foreground="#6c7086" FontSize="11" FontFamily="Consolas" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Text="ScreenRecApp Dev Console" Foreground="#45475a" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
