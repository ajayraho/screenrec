<Window x:Class="ScreenRecApp.LoaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Processing" Height="90" Width="300"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False">
    <Border Background="#1e1e2e" CornerRadius="8" BorderBrush="#313244" BorderThickness="1" Padding="15">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="StatusText" Text="Processing video..." Foreground="#89b4fa" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <ProgressBar IsIndeterminate="True" Width="220" Height="4" Foreground="#89b4fa" Background="#181825" BorderThickness="0" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="InfoText" Text="Saving in background. Don't panic." Foreground="#6c7086" FontSize="10" TextAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="CancelActionText" Text="Cancel AI features" Foreground="#f38ba8" FontSize="10" TextAlignment="Center" Cursor="Hand" TextDecorations="Underline" MouseLeftButtonDown="CancelAction_Click" Visibility="Collapsed"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
