<Window x:Class="ScreenRecApp.PromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Recording As" Height="200" Width="400"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ResizeMode="NoResize"
        Background="#1e1e2e" Foreground="White"
        WindowStyle="None" AllowsTransparency="True" BorderBrush="#313244" BorderThickness="1">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#89b4fa" />
            <Setter Property="Foreground" Value="#11111b" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#b4befe" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border CornerRadius="10" Background="#1e1e2e">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Text="Save Recording To" FontSize="18" FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,15" />
            
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="TimestampBox" Grid.Column="0" FontSize="16" Height="35" Width="140"
                         VerticalContentAlignment="Center" Background="#181825" Foreground="#cdd6f4"
                         BorderThickness="0" Margin="0,0,5,0" />
                         
                <ComboBox x:Name="NameComboBox" Grid.Column="1" IsEditable="True" 
                          FontSize="16" Height="35" Background="#181825" Foreground="#cdd6f4"
                          BorderThickness="0" VerticalContentAlignment="Center" PreviewKeyDown="NameComboBox_PreviewKeyDown">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="✕" Width="20" Height="20" Padding="0" 
                                        Background="Transparent" Foreground="#f38ba8" 
                                        Click="DeleteSuggestion_Click" Tag="{Binding}" Margin="5,0,0,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <TextBlock Text="✕" Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                
                <TextBlock Grid.Column="2" Text=".mp4" FontSize="16" Height="35"
                           VerticalAlignment="Center" Foreground="#a6adc8" Margin="5,0,0,0" Padding="0,5,0,0" />
            </Grid>
            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Save" Width="80" Height="35" Background="#89b4fa" Foreground="#11111b" 
                        FontWeight="SemiBold" BorderThickness="0" Margin="0,0,10,0" IsDefault="True" Click="Save_Click"/>
                <Button Content="Cancel" Width="80" Height="35" Background="#313244" Foreground="#cdd6f4" 
                        FontWeight="SemiBold" BorderThickness="0" IsCancel="True" Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
